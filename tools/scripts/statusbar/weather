#!/usr/bin/env bash

LOCATION="-6.9178185,107.7388819"
FULL=$(curl --max-time 5 -s wttr.in/"$LOCATION"?format="%x:%t\n")

c=$(echo "$FULL" | cut -d: -f1)
w=$(echo "$FULL" | cut -d: -f2)

icon="訷ｫ"
[[ -n $(echo "$c" | grep "^m$") ]] && icon="訷ｫ"
[[ -n $(echo "$c" | grep "!") ]] && icon="訷ｬ"
[[ -n $(echo "$c" | grep -E "\*|\.") ]] && icon="訷ｭ"
[[ -n $(echo "$c" | grep "o") ]] && icon="訷ｴ"
[[ -n $(echo "$c" | grep "x") ]] && icon="訷ｯ"

printf "%s%s" "$icon" "$w"

